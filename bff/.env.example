# BFF Environment Configuration
# Set to "false" to disable GraphiQL IDE in development
ENABLE_GRAPHIQL=true

# Comma-separated list of allowed CORS origins (default: *)
# ALLOWED_ORIGINS=http://localhost:5173,https://example.com

# Patient service URL (default: http://localhost:8081)
# PATIENT_SERVICE_URL=http://localhost:8081

# Server port (default: 4000)
# PORT=4000